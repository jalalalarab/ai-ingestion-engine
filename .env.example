# Copy this file to .env and fill in real values.
APP_ENV=local

# ---- Qdrant (vector store) ----
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=content_chunks

# ---- Embeddings (Ollama) ----
OLLAMA_BASE_URL=http://localhost:11434
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIM=768

# ---- Chunking ----
CHUNK_SIZE_TOKENS=700
CHUNK_OVERLAP_TOKENS=100
# "semantic" (embedding-similarity splits, better retrieval)
# or "simple" (fixed-size sliding window, faster fallback).
CHUNKING_STRATEGY=semantic

# ---- Upload limits ----
MAX_PDF_MB=50

# ---- LLM (Ollama Cloud) ----
LLM_MODEL=gpt-oss:20b-cloud
LLM_TIMEOUT_SECONDS=120

# ---- OCR (Tesseract) ----
# Windows: set the full path to tesseract.exe (there's no auto-discovery),
#   e.g. TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
# Linux/Mac: usually leave blank - Tesseract is found on the system PATH.
# If unset and Tesseract isn't on PATH, OCR (scanned PDFs, video frames) will fail.
TESSERACT_CMD=

# ---- Video frame sampling ----
# Sample one frame every N seconds (default 5). Lower = catch more, slower.
VIDEO_SAMPLE_SECONDS=5

# ---- Video transcription (OpenAI Whisper) ----
# OPENAI_API_KEY is a SECRET - put the real value in .env, never here or in git.
# Used for both Whisper transcription and gpt-4o-mini frame descriptions.
OPENAI_API_KEY=
WHISPER_MODEL=whisper-1
TRANSCRIBE_VIDEO=true

# ---- Minutes of Meeting ----
# Max characters of transcript per LLM call before map-reduce kicks in
# (~4 chars/token; 12000 chars ~= 3000 tokens input).
MOM_BATCH_CHARS=12000

# ---- Vision (frame description) ----
# Uses OpenAI gpt-4o-mini (reuses OPENAI_API_KEY above). Reads on-screen text
# AND describes each frame. Set DESCRIBE_FRAMES=false to use OCR only.
VISION_MODEL=gpt-4o-mini
VISION_TIMEOUT_SECONDS=120
DESCRIBE_FRAMES=true
