# Copy this file to .env and fill in real values.
APP_ENV=local

QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=content_chunks

OLLAMA_BASE_URL=http://localhost:11434
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIM=768

CHUNK_SIZE_TOKENS=700
CHUNK_OVERLAP_TOKENS=100
# Chunking strategy: "semantic" (embedding-similarity splits, better retrieval)
# or "simple" (fixed-size sliding window, faster fallback).
CHUNKING_STRATEGY=semantic

MAX_PDF_MB=50

# Video: sample one frame every N seconds (default 5). Lower = catch more, slower.
VIDEO_SAMPLE_SECONDS=5

# ---- LLM (Ollama Cloud) ----
LLM_MODEL=gpt-oss:20b-cloud
LLM_TIMEOUT_SECONDS=120
